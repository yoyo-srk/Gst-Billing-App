generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String     @id @default(cuid())
  email        String     @unique
  password     String
  businessName String?
  gstin        String?
  address      String?
  phone        String?
  state        String?
  logo         String?
  signature    String?
  bankDetails  String?
  primaryColor String?    @default("#0f172a")
  fontFamily   String?    @default("Inter")
  footerMessage String?
  role         UserRole   @default(USER)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  customers    Customer[]
  products     Product[]
  invoices     Invoice[]
  settings     Settings?
  businesses   Business[]
}

model Business {
  id        String   @id @default(cuid())
  name      String
  gstin     String?
  address   String?
  phone     String?
  state     String?
  logo      String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  invoices  Invoice[]
  products  Product[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Settings {
  id             String  @id @default(cuid())
  userId         String  @unique
  user           User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  showDiscount   Boolean @default(true)
  showHsn        Boolean @default(true)
  showSignature  Boolean @default(true)
  showBankDetails Boolean @default(true)
  showNotes      Boolean @default(true)
  defaultTemplate String @default("classic")
  invoicePrefix   String @default("INV")
  nextInvoiceNum  Int    @default(1)
  lowStockThreshold Int  @default(10)
}

model Customer {
  id        String    @id @default(cuid())
  name      String
  gstin     String?
  address   String?
  phone     String?
  email     String?
  state     String?
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  invoices  Invoice[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Product {
  id           String         @id @default(cuid())
  name         String
  hsn          String?
  price        Float
  gstRate      Float          @default(18)
  category     String?
  stock        Int            @default(0)
  lowStockAlert Int           @default(10)
  userId       String
  user         User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  businessId   String?
  business     Business?      @relation(fields: [businessId], references: [id])
  sizeVariants SizeVariant[]
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
}

model SizeVariant {
  id        String   @id @default(cuid())
  size      String
  stock     Int      @default(0)
  price     Float?
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Invoice {
  id            String        @id @default(cuid())
  invoiceNumber String
  customerId    String
  customer      Customer      @relation(fields: [customerId], references: [id])
  userId        String
  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  businessId    String?
  business      Business?     @relation(fields: [businessId], references: [id])
  invoiceDate   DateTime      @default(now())
  dueDate       DateTime?
  placeOfSupply String?
  sellerState   String?
  subtotal      Float         @default(0)
  cgst          Float         @default(0)
  sgst          Float         @default(0)
  igst          Float         @default(0)
  discount      Float         @default(0)
  total         Float         @default(0)
  status        InvoiceStatus @default(PENDING)
  notes         String?
  template      String        @default("classic")
  items         InvoiceItem[]
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
}

model InvoiceItem {
  id          String  @id @default(cuid())
  invoiceId   String
  invoice     Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  productName String
  hsn         String?
  quantity    Float   @default(1)
  price       Float
  discount    Float   @default(0)
  gstRate     Float   @default(18)
  total       Float
  size        String?
}

enum InvoiceStatus {
  DRAFT
  PENDING
  PAID
  OVERDUE
  CANCELLED
}

enum UserRole {
  ADMIN
  USER
}
